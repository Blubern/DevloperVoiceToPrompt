{
  "name": "developer-voice-to-prompt",
  "private": true,
  "version": "1.0.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/bundle-bridge.mjs && vite build",
    "build:lite": "npm run build",
    "build:full": "cross-env BUNDLE_NODE=true npm run build",
    "build:both": "node scripts/build-both.mjs",
    "bundle:bridge": "node scripts/bundle-bridge.mjs",
    "download:node": "node scripts/download-node.mjs",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.2",
    "@codemirror/language": "^6.12.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.17",
    "@github/copilot-sdk": "^0.1.33-unstable.1",
    "microsoft-cognitiveservices-speech-sdk": "^1.42.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@tauri-apps/api": "^2.2.0",
    "@tauri-apps/cli": "^2.2.0",
    "@tauri-apps/plugin-autostart": "^2.2.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.2.0",
    "@tauri-apps/plugin-global-shortcut": "^2.2.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2.2.0",
    "@tauri-apps/plugin-store": "^2.2.0",
    "@tauri-apps/plugin-updater": "^2.2.0",
    "@tsconfig/svelte": "^5.0.8",
    "esbuild": "^0.27.3",
    "jsdom": "^28.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tslib": "^2.8.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  }
}
